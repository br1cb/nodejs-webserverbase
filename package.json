{
  "name": "webserverbase",
  "version": "1.0.0",
  "description": "base for web server in nodejs",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --test dist/tests/**/*.test.js",
    "start": "node dist/index.js",
    "start:tsc": "tsc-watch --onSuccess \"npm run start\"",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v",
    "docker:rebuild": "docker-compose down -v && docker-compose up -d --build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/br1cb/webserverbase.git"
  },
  "keywords": [
    "server",
    "nodejs",
    "base",
    "template"
  ],
  "author": "Bruno César Barletta",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/br1cb/webserverbase/issues"
  },
  "homepage": "https://github.com/br1cb/webserverbase#readme",
  "devDependencies": {
    "@types/node": "^24.2.1",
    "dotenv": "^17.2.3",
    "tsc-watch": "^7.1.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "mariadb": "^3.4.5"
  }
}
